{
  "name": "local-produce-exchange",
  "private": true,
  "scripts": {
    "setup": "npm --prefix frontend ci && uv sync --locked --all-groups --directory backend",
    "frontend": "npm --prefix frontend run dev",
    "fix:frontend": "npm --prefix frontend ci",
    "backend": "uv run --locked --directory backend uvicorn app.main:app --reload --port 8000 --log-level debug",
    "fix:backend": "uv sync --locked --reinstall --all-groups --directory backend",
    "db": "docker compose up db",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:reset": "docker compose down --volumes",
    "db:seed": "uv run --locked --directory backend python -m app.seed",
    "build": "npm --prefix frontend run build",
    "typecheck": "npm --prefix frontend run typecheck",
    "preview": "npm --prefix frontend run preview",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint:backend": "uv run --locked --all-groups --directory backend ruff check .",
    "test": "npm run test:frontend && npm run test:backend",
    "tests": "npm test",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "uv run --locked --all-groups --directory backend pytest"
  }
}
