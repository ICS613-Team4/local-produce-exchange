# Copy this file to .env only if you need to change a database setting.
# Nothing requires a .env file: docker-compose.yml and backend/app/db.py
# both fall back to these values when .env is absent.
# .env is gitignored; never commit real credentials.

POSTGRES_USER=produce
POSTGRES_PASSWORD=produce
POSTGRES_DB=produce_exchange

# Change this if port 5432 is already used on your machine.
POSTGRES_PORT=5432
