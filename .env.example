# Copy this file to .env only if you need to change a database setting.
# Nothing requires a .env file: docker-compose.yml and backend/app/db.py
# both fall back to these values when .env is absent.
# .env is gitignored; never commit real credentials.

POSTGRES_USER=produce
POSTGRES_PASSWORD=produce
POSTGRES_DB=produce_exchange

# Change this if port 5432 is already used on your machine.
POSTGRES_PORT=5432

# pgweb database browser (read-only).
# Local: leave the auth keys empty (or skip the .env entirely). pgweb then runs
#   with no login on http://localhost:8081.
# Prod: the one shared team web login is set in the VPS .env (and posted in the
#   team Discord channel). The deploy refuses to start pgweb if either is empty.
PGWEB_AUTH_USER=
PGWEB_AUTH_PASS=

# Read-only database login that pgweb connects as. Leave this unset locally:
# the local database creates a pgweb_ro role with a built-in default password,
# and pgweb falls back to it. Production sets a strong value here that matches
# the pgweb_ro role created on the server. It must be URL-safe, because it goes
# straight into pgweb's connection URL; an "openssl rand -hex 24" value always
# is. The deploy refuses to start pgweb if it is empty.
# PGWEB_DB_PASSWORD=

# Optional local-only knob if 8081 is already taken. Production must stay on
# 8081 (nginx proxies to 8081), so do not set this in the production .env.
# PGWEB_PORT=8081
